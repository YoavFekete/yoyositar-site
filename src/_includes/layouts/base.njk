<!doctype html>
<html lang="en">
<head>

  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>
    {% if page.url == "/" %}
      {{ title }}
    {% else %}
      {{ title }} | YoYo Sitar
    {% endif %}
  </title>
  <meta name="description" content="{{ description }}" />

  <meta name="google-site-verification" content="v07Re1acRvA14puSIIfIGQ7gZuh_CIuMoSQAXPqbWHA" />

  <link rel="canonical" href="https://yoyositar.com{{ page.url }}">

  <!-- Open Graph -->
  <meta property="og:site_name" content="{{ site.title }}" />
  <meta property="og:title" content="{{ title }}" />
  <meta property="og:description" content="{{ description }}" />
  <meta property="og:url" content="https://yoyositar.com{{ page.url }}">
  <meta property="og:type" content="website" />

  <meta property="og:image" content="https://yoyositar.com/assets/img/og-image.jpg">
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="1043" />


  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ title }} — {{ site.title }}" />
  <meta name="twitter:description" content="{{ description }}" />
  <meta name="twitter:image" content="https://yoyositar.com/assets/img/og-image.jpg">

  <meta name="theme-color" content="#000000">

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Person",
    "name": "YoYo Sitar",
    "jobTitle": "Sitarist and Composer",
    "url": "https://yoyositar.com/",
    "image": "https://yoyositar.com/assets/img/og-image.jpg",
    "sameAs": [
      "{{ site.social.instagram }}",
      "{{ site.social.youtube }}",
      "{{ site.social.bandcamp }}",
      "{{ site.social.spotify }}"
    ],
    "genre": ["Indian classical", "World fusion",  "Afro-Indian fusion", "Improvised music, R"],
    "description": "Contemporary sitar artist blending Indian classical music with African, electronic and world fusion traditions."
  }
  </script>

  <meta name="robots" content="index,follow">

  <link rel="stylesheet" href="/assets/css/styles.css" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&display=swap" rel="stylesheet">
  <link rel="icon" href="/assets/favicon/favicon.ico" sizes="any">
  <link rel="icon" type="image/png" sizes="32x32" href="/assets/favicon/favicon-32x32.png">
  <link rel="icon" type="image/png" sizes="16x16" href="/assets/favicon/favicon-16x16.png">
  <link rel="apple-touch-icon" href="/assets/favicon/apple-touch-icon.png">
</head>
<body class="{{ bodyClass | default('') }}">
  {% include "partials/header.njk" %}
  <main class="page">
    {{ content | safe }}
  </main>
  {% include "partials/footer.njk" %}
</body>
</html>