<!doctype html>
<html lang="en">
<head>

  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  {% set pageTitle = seoTitle or title %}
  <title>
    {% if page.url == "/" %}
      {{ pageTitle }}
    {% else %}
      {{ pageTitle }}
    {% endif %}
  </title>
  {# Build an absolute OG image URL with per-page override #}
  {% set ogImagePath = ogImage or '/assets/img/og/default.jpg' %}
  {% if ogImagePath | slice(0,4) == 'http' %}
    {% set ogImageUrl = ogImagePath %}
  {% else %}
    {% set base = site.url %}
    {% if base | slice(-1) == '/' %}
      {% set base = base | slice(0, -1) %}
    {% endif %}
    {% set ogImageUrl = base ~ ogImagePath %}
  {% endif %}
    
  <meta name="description" content="{{ description }}" />

  <meta name="google-site-verification" content="v07Re1acRvA14puSIIfIGQ7gZuh_CIuMoSQAXPqbWHA" />

  <link rel="canonical" href="https://yoyositar.com{{ page.url }}">

  <!-- Open Graph -->
  <meta property="og:site_name" content="{{ site.title }}" />
  <meta property="og:title" content="{{ pageTitle  }}" />
  <meta property="og:description" content="{{ description }}" />
  <meta property="og:url" content="https://yoyositar.com{{ page.url }}">
  <meta property="og:type" content="website" />

  <meta property="og:image" content="{{ ogImageUrl }}" />
  <meta property="og:image:secure_url" content="{{ ogImageUrl }}" />
  {% if ogImageAlt %}
    <meta property="og:image:alt" content="{{ ogImageAlt }}" />
  {% endif %}
  {# Optional if you supply them #}
  {% if ogImageWidth %}<meta property="og:image:width" content="{{ ogImageWidth }}" />{% endif %}
  {% if ogImageHeight %}<meta property="og:image:height" content="{{ ogImageHeight }}" />{% endif %}

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ pageTitle  }}" />
  <meta name="twitter:description" content="{{ description }}" />
  <meta name="twitter:image" content="{{ ogImageUrl }}" />
  {% if ogImageAlt %}
    <meta name="twitter:image:alt" content="{{ ogImageAlt }}" />
  {% endif %}

  <meta name="theme-color" content="#000000">

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Person",
    "name": "YoYo Sitar",
    "jobTitle": "Sitarist and Composer",
    "instrument": "Sitar"
    "url": "https://yoyositar.com/",
    "image": "https://yoyositar.com/assets/img/og-image.jpg",
    "sameAs": [
      "{{ site.social.instagram }}",
      "{{ site.social.youtube }}",
      "{{ site.social.bandcamp }}",
      "{{ site.social.spotify }}"
    ],
    "genre": ["Indian classical", "World fusion",  "Afro-Raga", "Improvised music", "Rock Raga"],
    "description": "Contemporary sitar artist blending Indian classical music with African, electronic and world fusion traditions."
  }
  </script>

  <meta name="robots" content="index,follow">

  <link rel="stylesheet" href="/assets/css/styles.css" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;500;600;700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
  <link rel="icon" href="/assets/favicon/favicon.ico" sizes="any">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link rel="icon" type="image/png" sizes="32x32" href="/assets/favicon/favicon-32x32.png">
  <link rel="icon" type="image/png" sizes="16x16" href="/assets/favicon/favicon-16x16.png">
  <link rel="apple-touch-icon" href="/assets/favicon/apple-touch-icon.png">
</head>


<script>
  document.addEventListener("DOMContentLoaded", function () {
    const toggle = document.querySelector(".nav-toggle");
    const nav = document.querySelector("#site-nav");
    const dropdown = document.querySelector(".nav-dropdown");
    const dropdownButton = dropdown ? dropdown.querySelector(".nav-parent") : null;

    if (toggle && nav) {
      toggle.addEventListener("click", function () {
        const isOpen = nav.classList.toggle("is-open");
        toggle.setAttribute("aria-expanded", isOpen ? "true" : "false");
        toggle.setAttribute("aria-label", isOpen ? "Close menu" : "Open menu");
      });
    }

    if (!dropdown || !dropdownButton) return;

    const closeDropdown = function () {
      dropdown.classList.remove("is-open");
      dropdownButton.setAttribute("aria-expanded", "false");
    };

    const openDropdown = function () {
      dropdown.classList.add("is-open");
      dropdownButton.setAttribute("aria-expanded", "true");
    };

    dropdownButton.addEventListener("click", function (event) {
      const isDesktopStaticMenu = window.matchMedia("(max-width: 900px)").matches || document.body.classList.contains("home");
      if (isDesktopStaticMenu) return;

      event.preventDefault();
      const isOpen = dropdown.classList.contains("is-open");
      if (isOpen) {
        closeDropdown();
      } else {
        openDropdown();
      }
    });

    document.addEventListener("click", function (event) {
      if (!dropdown.contains(event.target)) {
        closeDropdown();
      }
    });

    dropdown.addEventListener("keydown", function (event) {
      if (event.key === "Escape") {
        closeDropdown();
        dropdownButton.focus();
      }
    });
  });
</script>

<body class="{{ bodyClass | default('') }}">
  {% include "partials/header.njk" %}
  <main class="page">
    {{ content | safe }}
  </main>
  {% include "partials/footer.njk" %}
</body>
</html>
