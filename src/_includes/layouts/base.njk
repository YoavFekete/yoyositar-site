<!doctype html>
<html lang="en">
<head>

  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  {% set pageTitle = seoTitle or title %}
  <title>
    {% if page.url == "/" %}
      {{ pageTitle }}
    {% else %}
      {{ pageTitle }}
    {% endif %}
  </title>
  {# Build an absolute OG image URL with per-page override #}
  {% set ogImagePath = ogImage or '/assets/img/og/default2.jpg' %}
  {% if ogImagePath | slice(0,4) == 'http' %}
    {% set ogImageUrl = ogImagePath %}
  {% else %}
    {% set base = site.url %}
    {% if base | slice(-1) == '/' %}
      {% set base = base | slice(0, -1) %}
    {% endif %}
    {% set ogImageUrl = base ~ ogImagePath %}
  {% endif %}
    
  <meta name="description" content="{{ description }}" />

  <meta name="google-site-verification" content="v07Re1acRvA14puSIIfIGQ7gZuh_CIuMoSQAXPqbWHA" />

  <link rel="canonical" href="https://yoyositar.com{{ page.url }}">

  <!-- Open Graph -->
  <meta property="og:site_name" content="{{ site.title }}" />
  <meta property="og:title" content="{{ pageTitle  }}" />
  <meta property="og:description" content="{{ description }}" />
  <meta property="og:url" content="https://yoyositar.com{{ page.url }}">
  <meta property="og:type" content="website" />

  <meta property="og:image" content="{{ ogImageUrl }}" />
  <meta property="og:image:secure_url" content="{{ ogImageUrl }}" />
  {% if ogImageAlt %}
    <meta property="og:image:alt" content="{{ ogImageAlt }}" />
  {% endif %}
  {# Optional if you supply them #}
  {% if ogImageWidth %}<meta property="og:image:width" content="{{ ogImageWidth }}" />{% endif %}
  {% if ogImageHeight %}<meta property="og:image:height" content="{{ ogImageHeight }}" />{% endif %}

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ pageTitle  }}" />
  <meta name="twitter:description" content="{{ description }}" />
  <meta name="twitter:image" content="{{ ogImageUrl }}" />
  {% if ogImageAlt %}
    <meta name="twitter:image:alt" content="{{ ogImageAlt }}" />
  {% endif %}

  <meta name="theme-color" content="#000000">

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Person",
    "name": "YoYo Sitar",
    "jobTitle": "Sitarist and Composer",
    "instrument": "Sitar"
    "url": "https://yoyositar.com/",
    "image": "https://yoyositar.com/assets/img/og-image.jpg",
    "sameAs": [
      "{{ site.social.instagram }}",
      "{{ site.social.youtube }}",
      "{{ site.social.bandcamp }}",
      "{{ site.social.spotify }}"
    ],
    "genre": ["Indian classical", "World fusion",  "Afro-Raga", "Improvised music", "Rock Raga"],
    "description": "Contemporary sitar artist blending Indian classical music with African, electronic and world fusion traditions."
  }
  </script>

  <meta name="robots" content="index,follow">

  <link rel="stylesheet" href="/assets/css/styles.css" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;500;600;700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
  <link rel="icon" href="/assets/favicon/favicon.ico" sizes="any">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link rel="icon" type="image/png" sizes="32x32" href="/assets/favicon/favicon-32x32.png">
  <link rel="icon" type="image/png" sizes="16x16" href="/assets/favicon/favicon-16x16.png">
  <link rel="apple-touch-icon" href="/assets/favicon/apple-touch-icon.png">
</head>


<script>
  document.addEventListener("DOMContentLoaded", function () {
    const state = {
      player: null,
      button: null,
      label: null,
      audio: null,
      source: null,
      kicker: null,
      title: null,
      isNavigating: false,
      youTubeApiReady: false,
      youTubePlayers: []
    };

    function getElements() {
      if (state.player && document.body.contains(state.player)) return state;

      state.player = document.querySelector("[data-global-audio-player]");
      state.button = state.player ? state.player.querySelector(".hero-audio-toggle") : null;
      state.label = state.player ? state.player.querySelector(".hero-audio-label") : null;
      state.audio = state.player ? state.player.querySelector(".hero-audio-element") : null;
      state.source = state.audio ? state.audio.querySelector("source") : null;
      state.kicker = state.player ? state.player.querySelector(".hero-audio-kicker") : null;
      state.title = state.player ? state.player.querySelector(".hero-audio-title") : null;
      return state;
    }

    function getPageAudioConfig(doc) {
      const body = doc.body;
      if (!body) {
        return { audioSrc: "", audioKicker: "", audioTitle: "", audioMode: "header" };
      }

      return {
        audioSrc: body.dataset.pageAudioSrc || "",
        audioKicker: body.dataset.pageAudioKicker || "",
        audioTitle: body.dataset.pageAudioTitle || "",
        audioMode: body.dataset.pageAudioMode || "header"
      };
    }

    function getCurrentTrack() {
      const elements = getElements();
      if (!elements.source) return "";
      return elements.source.getAttribute("src") || "";
    }

    function setPlayingState(isPlaying) {
      const elements = getElements();
      if (!elements.player || !elements.button || !elements.label) return;

      elements.player.classList.toggle("is-playing", isPlaying);
      elements.button.setAttribute("aria-pressed", isPlaying ? "true" : "false");
      elements.button.setAttribute("aria-label", isPlaying ? "Pause featured track" : "Play featured track");
      elements.label.textContent = isPlaying ? "Pause" : "Listen";
    }

    function pauseGlobalAudio() {
      const elements = getElements();
      if (!elements.audio || elements.audio.paused) return;

      elements.audio.pause();
      setPlayingState(false);
    }

    function pauseYouTubePlayers(activeIframe) {
      if (!state.youTubePlayers.length || !window.YT || !window.YT.PlayerState) return;

      state.youTubePlayers.forEach(function (entry) {
        if (!entry || !entry.player || !entry.iframe) return;
        if (activeIframe && entry.iframe === activeIframe) return;

        try {
          if (typeof entry.player.getPlayerState === "function" && entry.player.getPlayerState() === window.YT.PlayerState.PLAYING) {
            entry.player.pauseVideo();
          }
        } catch (error) {
          // Ignore YouTube API timing errors.
        }
      });
    }

    function setPlayerVisibility(isVisible) {
      const elements = getElements();
      if (!elements.player || !elements.button) return;

      elements.player.classList.toggle("is-hidden", !isVisible);
      elements.button.disabled = !isVisible;
    }

    function setPlayerMode(mode) {
      const elements = getElements();
      if (!elements.player) return;

      const nextMode = mode === "home" ? "home" : "header";
      elements.player.classList.toggle("hero-audio--home", nextMode === "home");
      elements.player.classList.toggle("hero-audio--header", nextMode !== "home");
    }

    function setPlayerCopy(config) {
      const elements = getElements();
      if (elements.kicker) elements.kicker.textContent = config.audioKicker || "";
      if (elements.title) elements.title.textContent = config.audioTitle || "";
    }

    function syncPlayerToConfig(config, options) {
      const elements = getElements();
      if (!elements.player || !elements.audio || !elements.source) return;

      const settings = options || {};
      const hadTrack = Boolean(getCurrentTrack());
      const wasPlaying = !elements.audio.paused && !elements.audio.ended;
      const nextTrack = config.audioSrc || "";

      setPlayerMode(config.audioMode);

      if (!nextTrack) {
        if (settings.preserveExisting && hadTrack) {
          setPlayerVisibility(true);
          return;
        }

        elements.audio.pause();
        elements.audio.removeAttribute("src");
        elements.source.removeAttribute("src");
        elements.audio.load();
        setPlayerCopy({ audioKicker: "", audioTitle: "" });
        setPlayerVisibility(false);
        setPlayingState(false);
        return;
      }

      setPlayerVisibility(true);
      setPlayerCopy(config);

      if (getCurrentTrack() === nextTrack) {
        if (settings.forcePlay && elements.audio.paused) {
          elements.audio.play().then(function () {
            pauseYouTubePlayers();
            setPlayingState(true);
          }).catch(function () {
            setPlayingState(false);
          });
        } else {
          setPlayingState(!elements.audio.paused && !elements.audio.ended);
        }
        return;
      }

      elements.source.setAttribute("src", nextTrack);
      elements.audio.load();

      if (settings.forcePlay || wasPlaying) {
        elements.audio.play().then(function () {
          pauseYouTubePlayers();
          setPlayingState(true);
        }).catch(function () {
          setPlayingState(false);
        });
        return;
      }

      setPlayingState(false);
    }

    function closeDropdown() {
      const dropdown = document.querySelector(".nav-dropdown");
      const dropdownButton = dropdown ? dropdown.querySelector(".nav-parent") : null;
      if (!dropdown || !dropdownButton) return;

      dropdown.classList.remove("is-open");
      dropdownButton.setAttribute("aria-expanded", "false");
    }

    function toggleMenu() {
      const toggle = document.querySelector(".nav-toggle");
      const nav = document.querySelector("#site-nav");
      if (!toggle || !nav) return;

      const isOpen = nav.classList.toggle("is-open");
      toggle.setAttribute("aria-expanded", isOpen ? "true" : "false");
      toggle.setAttribute("aria-label", isOpen ? "Close menu" : "Open menu");
    }

    function toggleDropdown(event) {
      const dropdown = event.target.closest(".nav-dropdown");
      const button = event.target.closest(".nav-parent");
      if (!dropdown || !button) return;

      const isDesktopStaticMenu = window.matchMedia("(max-width: 900px)").matches || document.body.classList.contains("home");
      if (isDesktopStaticMenu) return;

      event.preventDefault();
      const isOpen = dropdown.classList.contains("is-open");
      dropdown.classList.toggle("is-open", !isOpen);
      button.setAttribute("aria-expanded", isOpen ? "false" : "true");
    }

    function isPlainLeftClick(event) {
      return event.button === 0 && !event.metaKey && !event.ctrlKey && !event.shiftKey && !event.altKey;
    }

    function shouldHandleLink(link, event) {
      if (!link || !isPlainLeftClick(event)) return false;
      if (link.target && link.target !== "_self") return false;
      if (link.hasAttribute("download")) return false;
      if (link.getAttribute("rel") === "external") return false;
      if (link.origin !== window.location.origin) return false;
      if (link.hash && link.pathname === window.location.pathname && link.search === window.location.search) return false;
      return true;
    }

    function initYouTubePlayers(root) {
      if (!state.youTubeApiReady || !window.YT || !window.YT.Player) return;

      const scope = root || document;
      const iframes = scope.querySelectorAll("iframe[data-youtube-embed]");

      iframes.forEach(function (iframe) {
        if (iframe.dataset.ytInitialized === "true") return;

        iframe.dataset.ytInitialized = "true";
        const player = new window.YT.Player(iframe, {
          events: {
            onStateChange: function (event) {
              if (event.data === window.YT.PlayerState.PLAYING) {
                pauseGlobalAudio();
              }
            }
          }
        });

        state.youTubePlayers.push({ iframe: iframe, player: player });
      });
    }

    function loadYouTubeApi() {
      if (!document.querySelector("iframe[data-youtube-embed]")) return;

      if (window.YT && window.YT.Player) {
        state.youTubeApiReady = true;
        initYouTubePlayers(document);
        return;
      }

      if (document.querySelector("script[data-youtube-iframe-api]")) return;

      const previousReady = window.onYouTubeIframeAPIReady;
      window.onYouTubeIframeAPIReady = function () {
        state.youTubeApiReady = true;
        if (typeof previousReady === "function") previousReady();
        initYouTubePlayers(document);
      };

      const script = document.createElement("script");
      script.src = "https://www.youtube.com/iframe_api";
      script.async = true;
      script.dataset.youtubeIframeApi = "true";
      document.head.appendChild(script);
    }

    function syncHead(nextDoc) {
      document.title = nextDoc.title;

      const selectors = [
        'meta[name="description"]',
        'link[rel="canonical"]',
        'meta[property="og:title"]',
        'meta[property="og:description"]',
        'meta[property="og:url"]',
        'meta[property="og:image"]',
        'meta[property="og:image:secure_url"]',
        'meta[property="og:image:alt"]',
        'meta[property="og:image:width"]',
        'meta[property="og:image:height"]',
        'meta[name="twitter:title"]',
        'meta[name="twitter:description"]',
        'meta[name="twitter:image"]',
        'meta[name="twitter:image:alt"]'
      ];

      selectors.forEach(function (selector) {
        const currentNode = document.head.querySelector(selector);
        const nextNode = nextDoc.head.querySelector(selector);

        if (currentNode && nextNode) {
          currentNode.replaceWith(nextNode.cloneNode(true));
        } else if (currentNode && !nextNode) {
          currentNode.remove();
        } else if (!currentNode && nextNode) {
          document.head.appendChild(nextNode.cloneNode(true));
        }
      });
    }

    function syncBodyAttributes(nextBody) {
      document.body.className = nextBody.className || "";

      ["pageAudioSrc", "pageAudioKicker", "pageAudioTitle", "pageAudioMode"].forEach(function (key) {
        if (nextBody.dataset[key]) {
          document.body.dataset[key] = nextBody.dataset[key];
        } else {
          delete document.body.dataset[key];
        }
      });
    }

    async function navigateTo(url, options) {
      if (state.isNavigating) return;
      state.isNavigating = true;

      const settings = options || {};

      try {
        const response = await fetch(url, {
          headers: {
            "X-Requested-With": "global-audio-player"
          }
        });

        if (!response.ok) throw new Error("Navigation failed");

        const html = await response.text();
        const nextDoc = new DOMParser().parseFromString(html, "text/html");
        const nextMain = nextDoc.querySelector("main.page");
        const currentMain = document.querySelector("main.page");
        const nextChrome = nextDoc.querySelector("[data-site-chrome]");
        const currentChrome = document.querySelector("[data-site-chrome]");

        if (!nextMain || !currentMain || !nextChrome || !currentChrome || !nextDoc.body) {
          throw new Error("Incomplete page shell");
        }

        currentMain.innerHTML = nextMain.innerHTML;
        currentChrome.innerHTML = nextChrome.innerHTML;

        syncHead(nextDoc);
        syncBodyAttributes(nextDoc.body);
        syncPlayerToConfig(getPageAudioConfig(nextDoc), { preserveExisting: true });
        loadYouTubeApi();
        initYouTubePlayers(document);
        closeDropdown();

        if (!settings.fromPopState) {
          window.history.pushState({}, "", url);
        }

        window.scrollTo({ top: 0, left: 0, behavior: "auto" });
      } catch (error) {
        window.location.href = url;
      } finally {
        state.isNavigating = false;
      }
    }

    document.addEventListener("click", function (event) {
      if (event.target.closest(".nav-toggle")) {
        event.preventDefault();
        toggleMenu();
        return;
      }

      if (event.target.closest(".nav-parent")) {
        toggleDropdown(event);
        return;
      }

      const audioButton = event.target.closest(".hero-audio-toggle");
      if (audioButton) {
        event.preventDefault();
        const elements = getElements();
        if (!elements.audio || !getCurrentTrack()) return;

        if (elements.audio.paused) {
          elements.audio.play().then(function () {
            pauseYouTubePlayers();
            setPlayingState(true);
          }).catch(function () {
            setPlayingState(false);
          });
        } else {
          elements.audio.pause();
          setPlayingState(false);
        }
        return;
      }

      const link = event.target.closest("a[href]");
      if (!shouldHandleLink(link, event)) {
        const dropdown = document.querySelector(".nav-dropdown");
        if (dropdown && !dropdown.contains(event.target)) {
          closeDropdown();
        }
        return;
      }

      event.preventDefault();
      navigateTo(link.href);
    });

    document.addEventListener("keydown", function (event) {
      if (event.key === "Escape") {
        closeDropdown();
      }
    });

    window.addEventListener("popstate", function () {
      navigateTo(window.location.href, { fromPopState: true });
    });

    const elements = getElements();
    if (elements.audio) {
      elements.audio.addEventListener("ended", function () {
        elements.audio.currentTime = 0;
        setPlayingState(false);
      });

      elements.audio.addEventListener("pause", function () {
        if (!elements.audio.ended) {
          setPlayingState(false);
        }
      });

      elements.audio.addEventListener("play", function () {
        pauseYouTubePlayers();
        setPlayingState(true);
      });
    }

    loadYouTubeApi();
    syncPlayerToConfig(getPageAudioConfig(document), { preserveExisting: false });
    initYouTubePlayers(document);
  });
</script>

<body
  class="{{ bodyClass | default('') }}"
  data-page-audio-src="{{ audioSrc | default('') }}"
  data-page-audio-kicker="{{ audioKicker | default('') | escape }}"
  data-page-audio-title="{{ audioTitle | default('') | escape }}"
  data-page-audio-mode="{% if page.url == '/' %}home{% else %}header{% endif %}"
>
  {% include "partials/header.njk" %}
  <main class="page">
    {{ content | safe }}
  </main>
  {% include "partials/footer.njk" %}
</body>
</html>



